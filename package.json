{
  "name": "desktop-pet",
  "version": "1.0.0",
  "description": "Windows桌面AI智能伙伴 - 你的桌面好朋友",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:utf8": "chcp 65001 >nul && electron .",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:dir": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "convert-icon": "node convert-svg-to-png.js"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "ai-assistant",
    "live2d"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "lottie-web": "^5.12.2",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.3.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "three": "^0.150.0"
  },
  "build": {
    "appId": "com.desktop.pet",
    "productName": "桌面伙伴",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}",
      "!logs/**",
      "!dist/**",
      "!*.log",
      "!config.json",
      "!.env",
      "!打包*.md",
      "!用户*.md",
      "!*.ps1",
      "!.codebuddy/**",
      "!check-package/**",
      "!temp-check/**",
      "!models/*.glb",
      "!models/*.gltf",
      "!models/*.model3.json"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": ["**/*.glb", "**/*.gltf", "**/*.model3.json"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "桌面伙伴"
    }
  }
}
